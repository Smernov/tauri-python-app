{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "package": {
    "productName": "TauriPythonApp",
    "version": "0.1.0"
  },
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "distDir": "../src",
    "devPath": "../src"
  },
  "tauri": {
    "bundle": {
      "identifier": "com.tauri.python.app",
      "icon": [],
      "targets": ["exe"]
    },
    "windows": [
      {
        "title": "Tauri Python App",
        "width": 800,
        "height": 600
      }
    ],
    "allowlist": {
      "all": true
    },
    "security": {
      "csp": null
    }
  }
}
